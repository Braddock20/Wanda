# ─────────────────────────────────────────────────────────────────────────
# Core Telegram
# ─────────────────────────────────────────────────────────────────────────
API_ID=123456
API_HASH=your_api_hash_here
SESSION_STRING=   # leave empty if you have .session file

# ─────────────────────────────────────────────────────────────────────────
# Admin
# ─────────────────────────────────────────────────────────────────────────
# Comma-separated numeric Telegram user IDs. Admins run automation commands
# WITHOUT a prefix. Non-admins cannot trigger write actions.
AGENT_ADMIN_IDS=111111111,222222222

# ─────────────────────────────────────────────────────────────────────────
# Channel config (existing — unchanged)
# ─────────────────────────────────────────────────────────────────────────
AGENT_CHANNELS=[{"channel":"@mychannel","canPost":true,"canReact":true,"canComment":true,"canPin":true,"canForward":true,"canPullMedia":true,"maxVideoSeconds":60}]

# ─────────────────────────────────────────────────────────────────────────
# AI providers (existing — unchanged)
# ─────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# AI mode: on | off | hybrid
#   on     — every DM goes through the LLM agent (default)
#   off    — LLM is never called; only automations + slash/noprefix commands
#   hybrid — automations and slash/noprefix commands skip AI; DMs still go through AI
AI_MODE=hybrid

# ─────────────────────────────────────────────────────────────────────────
# Automations — JSON object. Each automation has its own enable flag.
# Anything omitted = sensible default.
# ─────────────────────────────────────────────────────────────────────────
# Top-level shape:
# {
#   "autolike":   { "enabled": true,  "chats": ["@channel1","-100..."], "emojis": ["❤️","🔥","👍","😍","💯","👏"] },
#   "autoreact":  { "enabled": true,  "chats": [...], "rules": [{"match":"hello","emojis":["👋"]},{"match":".*","emojis":["❤️","🔥"]}] },
#   "autopost":   { "enabled": true,  "fromChannels": ["@source1"], "toChat": "me", "withCaption": true },
#   "autosave":   { "enabled": true,  "chats": [...], "types": ["photo","video","document","voice"] },
#   "antidel":    { "enabled": true,  "maxCache": 1000, "saveMedia": true, "chats": "all" },
#   "antiedit":   { "enabled": true,  "maxCache": 1000 },
#   "autoreply":  { "enabled": false, "rules": [{"match":"ping","reply":"pong"}] },
#   "autoforward":{ "enabled": false, "fromChats":[...], "toChat":"...", "match":"..." },
#   "autopurge":  { "enabled": false, "selfMessages": true, "afterSeconds": 300 },
#   "autoread":   { "enabled": true,  "chats":"all" },
#   "autotyping": { "enabled": false, "chats":[...] },
#   "autobio":    { "enabled": false, "intervalMinutes":60, "pool":["building cool stuff","available"] },
#   "antiraid":   { "enabled": true,  "windowSeconds":10, "joinThreshold":5, "action":"leave" },
#   "scheduler":  { "enabled": true,  "tasks":[{"cron":"0 9 * * *","chat":"me","text":"good morning"}] },
#   "zipchannel": { "enabled": true,  "maxItems": 50 }
# }
AUTOMATIONS={"autolike":{"enabled":true,"emojis":["❤️","🔥","👍","😍","💯","👏","✨"]},"autoread":{"enabled":true},"antidel":{"enabled":true,"saveMedia":true}}

# ─────────────────────────────────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────────────────────────────────
DOWNLOAD_DIR=./downloads
ANTIDEL_DIR=./antidel-cache
PORT=3000
MAX_HISTORY=30
MAX_AGENT_STEPS=8
MAX_RETRIES=3
BACKOFF_BASE_MS=2000
SYSTEM_PROMPT=You are a helpful, friendly personal assistant replying on Telegram. Keep answers concise and natural, like texting.
